<?xml version="1.0" encoding="utf-8"?>
<!--
  Canonical color palette for my-watch.

  Single source of truth for the color scheme. The Huawei Band format has NO
  color attributes — colors are baked into the rendered bitmaps. So these values
  are consumed by tools/render_assets.py, which paints the glyph images in them.
  To recolor an element, render a glyph set in a different token (see
  docs/layout-spec.md) and point that widget at the new folder in Theme Studio.
-->
<Colors>
  <!-- Absolute black. On AMOLED this means pixels OFF: best battery life and
       no burn-in risk. Used as the canvas; do not ship a black PNG for it. -->
  <Color name="background"    value="#000000" />

  <!-- Warning red, tuned to evoke a car dashboard telltale (brake/ABS/engine):
       saturated and slightly warm so it "glows" against black rather than
       reading flat like pure #FF0000. Reserve for alerts / critical states. -->
  <Color name="danger_red"    value="#FF2116" />

  <!-- Primary accent — warm amber-yellow. Main highlight color. -->
  <Color name="primary"       value="#FFDA33" />

  <!-- Alternate accent — cyan/teal. Secondary highlight, contrasts primary. -->
  <Color name="alternate"     value="#00FFD4" />

  <!-- Standard — muted warm tan for regular text/labels. -->
  <Color name="standard"      value="#AB7C5F" />

  <!-- Standard dark — near-black warm brown for subtle fills / low emphasis. -->
  <Color name="standard_dark" value="#1B130E" />
</Colors>
